    `Generate a plan for the following person:`,
    ``,
    `Name: ${intake.name || "(not provided)"}`,
    `Age: ${intake.age}`,
    `Sex: ${intake.sex}`,
    `Height: ${intake.height_cm} cm`,
    `Weight: ${intake.weight_kg} kg`,
    `Activity level: ${intake.activity_level}`,
    `Primary goal: ${intake.primary_goal}`,
