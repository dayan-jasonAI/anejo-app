    }
  }
  return {
    outcome: "success",
    output: { date, expected: expected.length, missing: missing.length, missing_staff: missing.map((m) => m.name || m.id) },
    summary: `EOD chase for ${date}: ${missing.length} of ${expected.length} reports missing.`
  };
}
