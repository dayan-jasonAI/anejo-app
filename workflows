name: CI — auth tests + lint
on:
  push:
    branches: [studio-react-pilot]
  pull_request:
jobs:
  functions:
    name: Añejo Functions — test/auth + lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 24, cache: npm }
      - run: npm ci
      - run: npm run lint
      - run: npm run test:auth
  hub-app:
    name: hub-app (React) — lint + test/auth + build
    runs-on: ubuntu-latest
    defaults: { run: { working-directory: hub-app } }
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 24, cache: npm, cache-dependency-path: hub-app/package-lock.json }
      - run: npm ci
      - run: npm run lint
      - run: npm run test:auth
      - run: npm run build
